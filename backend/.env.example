ENVIRONMENT=dev # Options: dev, qa, prod
PROJECT_NAME=Big Skill Challenge MVP
SECRET_KEY=supersecretkey_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=*

# DB settings
POSTGRES_USER=bigskill
POSTGRES_PASSWORD=bigskill_password
POSTGRES_DB=bigskill_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_URL=redis://localhost:6379/0

# SMTP Settings
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME="Big Skill Challenge"

# LLM Settings
LLM_API_KEY=
LLM_PROVIDER=mock # Options: mock, groq, ollama, gemini
LLM_MODEL=llama-3.3-70b-versatile # Optional: Specific model name for the provider

# LangSmith Tracing (Debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__your_api_key_here
LANGCHAIN_PROJECT="Big-Skill-Challenge"

# -----------------------------------------------------------------------
# Competition integrity
# -----------------------------------------------------------------------
# Max creative entries per participant per competition (default: 10)
MAX_ENTRIES_PER_USER=10
# Minutes after quiz pass within which a submission is accepted (0 = disabled)
SUBMISSION_WINDOW_MINUTES=60

# -----------------------------------------------------------------------
# Stripe payment integration
# Get these from https://dashboard.stripe.com/apikeys
# Leave blank to run in mock mode (no real payments — for local dev only)
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
